{
  "id": "sdp",
  "title": "Spheres of the Depths",
  "description": "A custom tabletop RPG system for Foundry VTT",
  "version": "0.0.1",
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "authors": [
    {
      "name": "Danazen"
    }
  ],
  "esmodules": [
    "module/sdp.js"
  ],
  "styles": [
    "styles/sdp.css"
  ],

  "url": "https://github.com/danazen30/Foundry-system-Spheres-des-Profondeurs",
  "manifest": "",
  "download": "",

  "documentTypes": {
