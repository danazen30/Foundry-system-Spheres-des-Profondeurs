{
  "id": "sdp",
  "title": "Spheres of the Depths",
  "description": "A custom tabletop RPG system for Foundry VTT",
  "version": "0.0.1",
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "authors": [
    {
      "name": "Danazen"
    }
  ],
  "esmodules": [
    "module/sdp.js"
  ],
  "styles": [
    "styles/sdp.css"
  ],


  "url": "https://github.com/danazen30/Foundry-system-Spheres-des-Profondeurs",
  "manifest": "",
  "download": "",

  "initiative": "1d20 + @attributes.initiative.value",

  "packs": [

    {
      "name": "conditions",
      "label": "SDP Conditions",
      "system": "sdp",
      "path": "packs/conditions",
      "type": "Item"
    },

    {
      "name": "injuries",
      "label": "SDP Injuries",
      "system": "sdp",
      "path": "packs/injuries",
      "type": "Item"
    },

    {
      "name": "traits",
      "label": "SDP Traits",
      "system": "sdp",
      "path": "packs/traits",
      "type": "Item"
    },

    {
      "name": "talents",
      "label": "SDP Talents",
      "system": "sdp",
      "path": "packs/talents",
      "type": "Item"
    },

    {
      "name": "skills",
      "label": "SDP Skills",
      "system": "sdp",
      "path": "packs/skills",
      "type": "Item"
    },

    {
      "name": "weapons",
      "label": "SDP Weapons",
      "system": "sdp",
      "path": "packs/weapons",
      "type": "Item"
    }

  ],

  "documentTypes": {
    "Actor": {
      "character": {
        "htmlFields": [
          "system.details.gmNotes.value",
          "system.details.playerNotes.value",
          "system.details.motivation.value",
          "system.details.personalAmbitions.value",
          "system.details.partyAmbitions.value"
        ]
      },
      "npc": {
        "htmlFields": [
          "system.details.gmNotes.value",
          "system.details.playerNotes.value",
          "system.details.motivation.value"
        ]
      },
      "creature": {
        "htmlFields": [
          "system.details.gmNotes.value",
          "system.details.playerNotes.value",
          "system.details.motivation.value"
        ]
      }
    },
    "Item": {
      "skill": {},
      "talent": {},
      "weapon": {},
      "armor": {},
      "spell": {},
      "condition": {},
      "injury": {}
    }
  }
}
