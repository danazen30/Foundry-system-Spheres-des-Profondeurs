<form class="{{cssClass}}" autocomplete="off">

<h1>{{actor.name}}</h1>

<div class="attributes-grid">

<div class="attr-header"></div>

{{#each system.attributes as |attr key|}}
<div class="attr-header">{{attr.label}}</div>
{{/each}}

<div class="attr-row">Init</div>
{{#each system.attributes as |attr key|}}
<input
type="number"
name="system.attributes.{{key}}.initial"
value="{{attr.initial}}">
{{/each}}

<div class="attr-row">Adv</div>
{{#each system.attributes as |attr key|}}
<input
type="number"
name="system.attributes.{{key}}.advances"
value="{{attr.advances}}">
{{/each}}

<div class="attr-row">Mod</div>
{{#each system.attributes as |attr key|}}
<input
type="number"
name="system.attributes.{{key}}.modifier"
value="{{attr.modifier}}">
{{/each}}

<div class="attr-row">Final</div>
{{#each system.attributes as |attr key|}}
<input
type="number"
value="{{attr.value}}"
class="roll-attribute"
data-attr="{{key}}"
readonly>
{{/each}}

</div>

<h2>Resources</h2>

<div class="health-container">

<label>Health</label>

<input
type="number"
name="system.health.value"
value="{{system.health.value}}">

<span>/ {{system.health.max}}</span>

</div>

<div class="resource-row">

<label>Mana</label>

<input
type="number"
name="system.resources.mana.value"
value="{{system.resources.mana.value}}">

</div>

<h2>Derived</h2>

<div class="derived">

<p>Parry : {{system.derived.parry.value}}</p>
<p>Evasion : {{system.derived.evasion.value}}</p>
<p>Wound Threshold : {{system.derived.woundThreshold.value}}</p>
<p>Attack : {{system.derived.attack.value}}</p>

</div>

<h2>Skills</h2>

<table class="skills-table">

<thead>
<tr>
<th>Name</th>
<th>Characteristic</th>
<th>Adv</th>
<th>Value</th>
</tr>
</thead>

<tbody>

{{#each actor.items as |item|}}
{{#if (eq item.type "skill")}}

<tr>

<td>{{item.name}}</td>

<td>{{item.system.characteristic}}</td>

<td>
<input
type="number"
class="skill-advances"
data-item-id="{{item.id}}"
value="{{item.system.advances}}">
</td>

<td
class="roll-skill"
data-item-id="{{item.id}}">

{{item.system.value}}

</td>

</tr>

{{/if}}
{{/each}}

</tbody>

</table>


<h2>Talents</h2>

<table class="talents-table">

<thead>
<tr>
<th>Name</th>
<th>Level</th>
<th>Max</th>
</tr>
</thead>

<tbody>

{{#each actor.items as |item|}}
{{#if (eq item.type "talent")}}

<tr>

<td>{{item.name}}</td>

<td>

<input
type="number"
class="talent-advances"
data-item-id="{{item.id}}"
value="{{item.system.advances}}"
min="0"

max="{{#if (lookup ../system.attributes item.system.max)}}{{lookup (lookup ../system.attributes item.system.max) "bonus"}}{{else}}{{item.system.max}}{{/if}}"

{{#unless item.system.canAdvance}}disabled{{/unless}}
>

</td>

<td>

{{#if (lookup ../system.attributes item.system.max)}}
{{lookup (lookup ../system.attributes item.system.max) "bonus"}}
{{else}}
{{item.system.max}}
{{/if}}

</td>

</tr>

{{/if}}
{{/each}}

</tbody>

</table>


<h2>Weapons</h2>

<table class="weapons-table">

<thead>
<tr>
<th>Name</th>
<th>Skill</th>
<th>Atk</th>
<th>Parry</th>
<th>Offhand</th>
<th>Equipped</th>
<th>Damage</th>
<th>Attack</th>
</tr>
</thead>

<tbody>

{{#each actor.items as |item|}}
{{#if (eq item.type "weapon")}}

<tr>

<td>{{item.name}}</td>

<td>{{item.system.skill}}</td>

<td>{{item.system.attackBonus}}</td>

<td>{{item.system.parryBonus}}</td>

<td>
<input
type="checkbox"
class="weapon-offhand"
data-item-id="{{item.id}}"
{{checked item.system.offhand}}>
</td>

<td>
<input
type="checkbox"
class="weapon-equipped"
data-item-id="{{item.id}}"
{{checked item.system.equipped}}>
</td>

<td>

{{item.system.finalDamage}}

{{#if item.system.damageDice}}
 + {{item.system.damageDice}}
{{/if}}

</td>


<td>
<button
class="weapon-attack"
data-item-id="{{item.id}}">
Attack
</button>
</td>

</tr>

{{/if}}
{{/each}}

</tbody>

</table>

<h2>Armors</h2>

<table class="armors-table">

<thead>
<tr>
<th>Name</th>
<th>Head</th>
<th>Body</th>
<th>L Arm</th>
<th>R Arm</th>
<th>L Leg</th>
<th>R Leg</th>
<th>Worn</th>
</tr>
</thead>

<tbody>

{{#each actor.items as |item|}}
{{#if (eq item.type "armor")}}

<tr>

<td>{{item.name}}</td>

<td>{{item.system.AP.head}}</td>

<td>{{item.system.AP.body}}</td>

<td>{{item.system.AP.leftArm}}</td>

<td>{{item.system.AP.rightArm}}</td>

<td>{{item.system.AP.leftLeg}}</td>

<td>{{item.system.AP.rightLeg}}</td>

<td>
<input
type="checkbox"
class="armor-worn"
data-item-id="{{item.id}}"
{{checked item.system.worn.value}}>
</td>

</tr>

{{/if}}
{{/each}}

</tbody>

</table>

<h2>Conditions</h2>

<section class="conditions">

<div class="condition-controls">

<button type="button" class="add-condition">
Add Condition
</button>

</div>

<ul class="conditions-list">

{{#each actor.items as |item|}}
{{#if (eq item.type "condition")}}

<li class="condition flexrow" data-item-id="{{item.id}}">

<span class="condition-name">
{{item.name}}
</span>

<input
type="number"
class="condition-stack-input"
data-item-id="{{item.id}}"
value="{{item.system.stack}}"
min="1"
style="width:40px"
/>

<button class="remove-condition" data-item-id="{{item.id}}">
Remove
</button>

</li>

{{/if}}
{{/each}}

</ul>

</section>